{
  "name": "app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "vite build && wrangler pages deploy .svelte-kit/cloudflare"
  },
  "dependencies": {
    "@hot-labs/near-connect": "^0.11.4",
    "@unocss/reset": "^66.7.0",
    "chess.js": "^1.4.0",
    "dayjs": "^1.11.21",
    "near-api-js": "^7.2.0",
    "unocss": "^66.7.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.9.1",
    "@unocss/postcss": "^66.7.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "unocss-preset-chinese": "^0.3.3",
    "vite": "^8.0.7",
    "vite-plugin-node-polyfills": "^0.28.0",
    "wrangler": "^4.97.0"
  }
}
