---
import site from "@/content/site.json";
import Icons from "@/components/Icons.astro";

const { faq } = site;
---

<section id="faq" class="relative py-24 sm:py-32">
  <div class="absolute inset-0 bg-bg" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-primary">{faq.title}</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-5xl">
        {faq.subtitle}
      </h2>
    </div>

    <div class="mt-16 space-y-4">
      {faq.items.map((item) => (
        <details class="group rounded-2xl border border-white/5 bg-white/[0.02] open:border-primary/20 open:bg-white/[0.04]">
          <summary class="flex cursor-pointer list-none items-center justify-between p-5 sm:p-6">
            <span class="pr-4 text-base font-semibold text-white sm:text-lg">{item.question}</span>
            <span class="flex-shrink-0 rounded-full bg-white/5 p-1 text-white/60 transition-transform group-open:rotate-180 group-open:text-primary">
              <Icons name="chevron-down" class="w-5 h-5" />
            </span>
          </summary>
          <div class="px-5 pb-6 pt-0 sm:px-6">
            <p class="text-base leading-relaxed text-white/60" set:html={item.answer} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
</style>
