---
import site from "@/content/site.json";
import Icons from "@/components/Icons.astro";

const { site: siteData, hero } = site;
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-20">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-bg to-surface" aria-hidden="true"></div>

  <!-- Decorative radial glow -->
  <div
    class="absolute left-1/2 top-1/3 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-primary/5 blur-3xl"
    aria-hidden="true"
  ></div>

  <!-- Chess board pattern overlay -->
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 60px 60px;"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm text-primary mb-8">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
      </span>
      Live on NEAR Protocol
    </div>

    <h1 class="mx-auto max-w-4xl text-4xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl">
      {hero.title}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-white/60 sm:text-xl">
      {hero.subtitle}
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={siteData.appUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-4 text-base font-semibold text-bg shadow-lg shadow-primary/20 hover:bg-primary-light transition-all hover:scale-105"
      >
        {hero.ctaPrimary}
        <Icons name="arrow-right" class="w-5 h-5" />
      </a>
      <a
        href="#features"
        class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-8 py-4 text-base font-semibold text-white hover:bg-white/10 transition-colors"
      >
        {hero.ctaSecondary}
      </a>
    </div>

    <div class="mt-16 grid grid-cols-2 gap-4 sm:grid-cols-4">
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-4">
        <div class="text-2xl font-bold text-primary sm:text-3xl">100%</div>
        <div class="mt-1 text-sm text-white/50">On-chain</div>
      </div>
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-4">
        <div class="text-2xl font-bold text-primary sm:text-3xl">4</div>
        <div class="mt-1 text-sm text-white/50">AI Levels</div>
      </div>
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-4">
        <div class="text-2xl font-bold text-primary sm:text-3xl">∞</div>
        <div class="mt-1 text-sm text-white/50">Verifiable Games</div>
      </div>
      <div class="rounded-2xl border border-white/5 bg-white/[0.02] p-4">
        <div class="text-2xl font-bold text-primary sm:text-3xl">NEAR</div>
        <div class="mt-1 text-sm text-white/50">Protocol</div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <Icons name="chevron-down" class="w-6 h-6 text-white/30" />
  </div>
</section>
